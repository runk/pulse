{
  "name": "basic policy",
  "checks": [
    {
      "type": "http",
      "url": "https://example.com",
      "assertions": [
        {
          "statusCode": {
            "equals": 200
          },
          "headers": {
            "Content-Type": {
              "matches": "text/html.*"
            }
          },
          "body": {
            "contains": "This domain is for use in documentation examples without needing permission"
          }
        },
        {
          "statusCode": {
            "between": [200, 299]
          },
          "body": {
            "matches": "<!doctype html><html lang=\"en\">.*</html>"
          }
        }
      ]
    }
  ]
}

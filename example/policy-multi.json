{
  "name": "basic policy",
  "checks": [
    {
      "type": "http",
      "method": "get",
      "url": "https://example.com",
      "assertions": [
        {
          "statusCode": {
            "equals": 200
          },
          "headers": {
            "Content-Type": {
              "matches": "text/html.*"
            }
          },
          "body": {
            "contains": "This domain is for use in documentation examples without needing permission"
          }
        }
      ]
    },
    {
      "type": "http",
      "url": "https://github.com"
    },
    {
      "type": "http",
      "url": "https://yahoo.com",
      "assertions": [
        {
          "statusCode": {
            "between": [400, 499]
          }
        }
      ]
    },
    {
      "type": "http",
      "url": "https://facebook.com"
    },
    {
      "type": "http",
      "url": "https://amazon.com"
    },
    {
      "type": "http",
      "url": "https://wikipedia.com",
      "assertions": [
        {
          "statusCode": {
            "equals": 403
          }
        }
      ]
    },
    {
      "type": "http",
      "url": "https://x.com"
    },
    {
      "type": "http",
      "url": "https://google.com"
    }
  ]
}
